<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>سفريات الأمان - حجز رحلات طيران</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@400;700&display=swap');
        body { font-family: 'Tajawal', sans-serif; background-color: #f0f7f9; }
    </style>
</head>
<body class="text-gray-800">

    <header class="bg-[#0a3d62] text-white py-6 shadow-xl rounded-b-3xl">
        <div class="container mx-auto px-4 text-center">
            <h1 class="text-3xl font-bold">سفريات الأمان</h1>
            <p class="mt-2 opacity-90">سوريا - صبيخان | دقة في المواعيد وأفضل الأسعار</p>
            <a href="https://wa.me/96555943343" class="mt-4 inline-block bg-[#2ecc71] hover:bg-[#27ae60] text-white font-bold py-2 px-6 rounded-full transition duration-300">
                <i class="fab fa-whatsapp"></i> تواصل عبر واتساب
            </a>
        </div>
    </header>

    <main class="container mx-auto px-4 py-8">
        <div class="bg-white p-6 rounded-2xl shadow-lg mb-8 border-t-4 border-[#3c6382]">
            <h2 class="text-xl font-bold mb-4 text-center text-[#0a3d62]">ابحث عن رحلتك الآن</h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                
                <div>
                    <label class="block mb-1 font-semibold">الوجهة:</label>
                    <select id="routeSelect" class="w-full border p-3 rounded-lg bg-gray-50 focus:ring-2 focus:ring-[#3c6382]">
                        <option value="KWI-DAM">الكويت (KWI) ⬅️ دمشق (DAM)</option>
                        <option value="DAM-KWI">دمشق (DAM) ⬅️ الكويت (KWI)</option>
                        <option value="DAM-DXB">دمشق (DAM) ⬅️ دبي (DXB)</option>
                        <option value="DAM-SHJ">دمشق (DAM) ⬅️ الشارقة (SHJ)</option>
                        <option value="DAM-BGW">دمشق (DAM) ⬅️ بغداد (BGW)</option>
                        <option value="DAM-EBL">دمشق (DAM) ⬅️ أربيل (EBL)</option>
                        <option value="DAM-RUH">دمشق (DAM) ⬅️ الرياض (RUH)</option>
                    </select>
                </div>

                <div>
                    <label class="block mb-1 font-semibold">موعد السفر:</label>
                    <select id="daysSelect" class="w-full border p-3 rounded-lg bg-gray-50">
                        </select>
                </div>

                <div class="flex items-end">
                    <button onclick="searchFlight()" class="w-full bg-[#3c6382] text-white font-bold py-3 rounded-lg hover:bg-[#0a3d62] transition duration-300">
                        عرض السعر النهائي 🔎
                    </button>
                </div>
            </div>
            <p class="text-xs text-red-500 mt-4 text-center font-bold">⚠️ الأسعار الظاهرة تشمل عمولة المكتب (12$)</p>
        </div>

        <div id="resultArea" class="hidden animate-pulse text-center py-10">
            <p class="text-[#0a3d62] font-bold">جاري البحث عن أفضل سعر متاح...</p>
        </div>

        <div id="priceCard" class="hidden max-w-md mx-auto bg-white rounded-3xl shadow-2xl overflow-hidden border-2 border-[#2ecc71]">
            <div class="bg-[#2ecc71] p-4 text-white text-center">
                <h3 id="cardRoute" class="text-lg font-bold"></h3>
            </div>
            <div class="p-8 text-center">
                <p class="text-gray-500 mb-2">السعر النهائي شامل العمولة</p>
                <div class="text-5xl font-black text-[#e43333] mb-4"><span id="finalPrice">0</span> <span class="text-xl">USD</span></div>
                <p id="travelDate" class="text-sm font-semibold bg-gray-100 py-2 rounded-lg"></p>
                <a href="https://wa.me/96555943343" id="confirmBtn" class="mt-6 block bg-[#0a3d62] text-white py-3 rounded-xl font-bold">تأكيد الحجز الآن</a>
            </div>
        </div>
    </main>

    <footer class="text-center py-10 text-gray-400 text-sm">
        سفريات الأمان © 2026 | يتم جلب البيانات من أنظمة طيران عالمية
    </footer>

    <script>
        const apiKey = '60109d1d5bmshcd7355d6eda564ep1ec25bjsn721a4f2f5979';
        const commission = 12;

        // توليد قائمة الأيام (من 1 إلى 15)
        const daysSelect = document.getElementById('daysSelect');
        for (let i = 1; i <= 15; i++) {
            let option = document.createElement('option');
            option.value = i;
            option.text = `بعد ${i} يوم`;
            daysSelect.appendChild(option);
        }

        async function searchFlight() {
            const route = document.getElementById('routeSelect').value.split('-');
            const from = route[0];
            const to = route[1];
            const daysToAdd = parseInt(document.getElementById('daysSelect').value);
            
            // حساب التاريخ
            let date = new Date();
            date.setDate(date.getDate() + daysToAdd);
            const formattedDate = `${String(date.getDate()).padStart(2, '0')}/${String(date.getMonth() + 1).padStart(2, '0')}/${date.getFullYear()}`;

            // إظهار اللودينج وإخفاء البطاقة القديمة
            document.getElementById('resultArea').classList.remove('hidden');
            document.getElementById('priceCard').classList.add('hidden');

            const url = `https://kiwi-com-cheap-flights.p.rapidapi.com/one-way?sourceCity=${from}&destinationCity=${to}&dateFrom=${formattedDate}&dateTo=${formattedDate}&currency=USD&adults=1`;

            try {
                const response = await fetch(url, {
                    method: 'GET',
                    headers: {
                        'x-rapidapi-key': apiKey,
                        'x-rapidapi-host': 'kiwi-com-cheap-flights.p.rapidapi.com'
                    }
                });
                const result = await response.json();

                document.getElementById('resultArea').classList.add('hidden');

                if (result.data && result.data.length > 0) {
                    const basePrice = result.data[0].price;
                    const finalPrice = Math.round(basePrice + commission);

                    document.getElementById('cardRoute').innerText = document.getElementById('routeSelect').options[document.getElementById('routeSelect').selectedIndex].text;
                    document.getElementById('finalPrice').innerText = finalPrice;
                    document.getElementById('travelDate').innerText = `تاريخ السفر: ${formattedDate}`;
                    document.getElementById('priceCard').classList.remove('hidden');
                } else {
                    alert("عذراً، لم نجد رحلات متوفرة لهذا التاريخ تحديداً. جرب يوماً آخر.");
                }
            } catch (error) {
                document.getElementById('resultArea').classList.add('hidden');
                alert("حدث خطأ في الاتصال بالنظام. تأكد من تفعيل اشتراك API.");
            }
        }
    </script>
</body>
</html>

